{
  "name":        "mediavault/backend",
  "description": "MediaVault PHP REST API",
  "type":        "project",
  "license":     "proprietary",
  "require": {
    "php":                         "^8.2",

    "slim/slim":                   "^4.13",
    "slim/psr7":                   "^1.6",

    "php-di/php-di":               "^7.0",

    "vlucas/phpdotenv":            "^5.6",

    "monolog/monolog":             "^3.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "MediaVault\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MediaVault\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 public/index.php"
  }
}
