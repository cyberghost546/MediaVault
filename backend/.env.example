# =============================================================================
# .env.example — ENVIRONMENT VARIABLE TEMPLATE
# =============================================================================
# Copy this file to ".env" and fill in your real values.
# NEVER commit ".env" to git — it contains secrets.
#
# HOW: cp .env.example .env
# =============================================================================

# Application environment: "development" or "production"
# In development, detailed error messages are shown.
# In production, generic error messages are shown (security).
APP_ENV=development

# A random secret key for signing tokens. Generate with:
#   openssl rand -hex 32
APP_SECRET=change-me-before-production

# ── DATABASE ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mediavault
DB_USERNAME=root
DB_PASSWORD=

# ── PATHS ──
# Where downloaded files are saved on the SERVER (not the user's device).
# For local development, use a relative path: ../storage/downloads
DOWNLOAD_PATH=./storage/downloads

# Path to the Python executable.
# Linux/macOS: python3
# Windows:     C:\Python311\python.exe
PYTHON_PATH=python3

# ── CORS ──
# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:3000

# ── LIMITS ──
MAX_CONCURRENT=5
EXTRACT_TIMEOUT=60
DOWNLOAD_TIMEOUT=3600
